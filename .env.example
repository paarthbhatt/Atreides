# Copy values into your shell or deployment secret store. Do not commit real values.
ATREIDES_POLICY_PATH=apps/gateway/policies/default.json
ATREIDES_RECEIPT_PATH=.atreides/receipts.jsonl
ATREIDES_RECEIPT_SIGNING_KEY=replace-with-a-long-random-secret
ATREIDES_RECEIPT_SIGNING_KEY_ID=local-dev-2026
ATREIDES_API_TOKEN=replace-with-a-long-random-token
ATREIDES_RATE_LIMIT_PER_MINUTE=120

# Optional: configure an upstream stdio MCP server for Atreides to discover and wrap.
# ATREIDES_UPSTREAM_COMMAND=npx
# ATREIDES_UPSTREAM_ARGS=["-y","<upstream-mcp-package>"]
# ATREIDES_UPSTREAM_CWD=C:\path\to\upstream
